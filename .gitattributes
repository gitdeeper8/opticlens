# Auto detect text files
* text=auto

# Python
*.py text diff=python
*.pyc binary
*.pyo binary
*.pyd binary

# Documents
*.md text
*.rst text
*.txt text
*.tex text

# Config
*.yml text
*.yaml text
*.json text
*.toml text
*.ini text
*.cfg text

# Data
*.csv text
*.npy binary
*.npz binary
*.h5 binary
*.hdf5 binary
*.nc binary
*.zarr binary

# Images
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.svg text
*.pdf binary

# Archives
*.zip binary
*.tar.gz binary
*.7z binary

# Git
.gitattributes export-ignore
.gitignore export-ignore

# Docs
docs/ export-ignore
tests/ export-ignore
examples/ export-ignore

# CI/CD
.github/ export-ignore
.gitlab/ export-ignore
